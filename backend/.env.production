# Application
APP_NAME=SehatSaheli
APP_ENV=production
DEBUG=false
API_V1_PREFIX=/api/v1

# Database (Supabase PostgreSQL)
# Format: postgresql+asyncpg://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql+asyncpg://YOUR_SUPABASE_CONNECTION_STRING
DATABASE_ECHO=false

# JWT — generate a strong random secret for production
JWT_SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_64_CHAR_STRING
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Google Gemini AI
GEMINI_API_KEY=your-gemini-api-key

# CORS — your Netlify frontend URL
CORS_ORIGINS=["https://your-app-name.netlify.app"]

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
